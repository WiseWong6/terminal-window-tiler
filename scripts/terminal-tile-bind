#!/bin/zsh

# Install a short command (e.g. "ts") that runs terminal-tile-all.
# Usage: terminal-tile-bind <abbr> [--force]

set -u

usage() {
  cat <<'EOF'
Usage:
  terminal-tile-bind <abbr> [--force]

Examples:
  terminal-tile-bind ts
  terminal-tile-bind tile --force
EOF
}

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage
  exit 1
fi

abbr="$1"
force=0
if [[ $# -eq 2 ]]; then
  if [[ "$2" != "--force" ]]; then
    usage
    exit 1
  fi
  force=1
fi

if ! print -r -- "$abbr" | grep -Eq '^[A-Za-z][A-Za-z0-9_-]{0,15}$'; then
  echo "缩写不合法：$abbr"
  echo "要求：以英文字母开头，只能包含字母、数字、下划线、短横线，长度 1~16。"
  exit 1
fi

reserved_words=(
  if then else elif fi
  for while until do done in
  case esac select function
  time coproc repeat
)
for word in "${reserved_words[@]}"; do
  if [[ "$abbr" == "$word" ]]; then
    echo "缩写 '$abbr' 是 shell 保留字，不能使用。"
    exit 1
  fi
done

bin_dir="$HOME/.local/bin"
target="$bin_dir/$abbr"
marker="generated by terminal-window-tiler"

conflicts=()

current_cmd="$(command -v -- "$abbr" 2>/dev/null || true)"
if [[ -n "$current_cmd" && "$current_cmd" != "$target" ]]; then
  conflicts+=("PATH 中已有同名命令: $current_cmd")
fi

rc_files=("$HOME/.zshrc" "$HOME/.zprofile" "$HOME/.bashrc" "$HOME/.bash_profile")
for rc in "${rc_files[@]}"; do
  [[ -f "$rc" ]] || continue

  alias_match="$(grep -nE "^[[:space:]]*alias[[:space:]]+${abbr}=" "$rc" 2>/dev/null | head -n 1 || true)"
  if [[ -n "$alias_match" ]]; then
    conflicts+=("$rc 中存在 alias: $alias_match")
  fi

  fn_match="$(grep -nE "^[[:space:]]*(function[[:space:]]+)?${abbr}[[:space:]]*\\(\\)[[:space:]]*\\{" "$rc" 2>/dev/null | head -n 1 || true)"
  if [[ -n "$fn_match" ]]; then
    conflicts+=("$rc 中存在 function: $fn_match")
  fi
done

if [[ -e "$target" ]]; then
  if ! grep -q "$marker" "$target" 2>/dev/null; then
    conflicts+=("目标文件已存在且非本工具生成: $target")
  fi
fi

if (( ${#conflicts[@]} > 0 && force == 0 )); then
  echo "检测到缩写冲突，未安装："
  for line in "${conflicts[@]}"; do
    echo "- $line"
  done
  echo
  echo "可改用其他缩写，或确认后使用 --force 覆盖："
  echo "  terminal-tile-bind $abbr --force"
  exit 2
fi

mkdir -p "$bin_dir"

cat > "$target" <<'EOF'
#!/bin/zsh
# generated by terminal-window-tiler

if command -v terminal-tile-all >/dev/null 2>&1; then
  exec "$(command -v terminal-tile-all)" "$@"
fi

SCRIPT_DIR="${0:A:h}"
if [[ -x "$SCRIPT_DIR/terminal-tile-all" ]]; then
  exec "$SCRIPT_DIR/terminal-tile-all" "$@"
fi

echo "terminal-tile-all 未找到，请先安装到 ~/.local/bin/terminal-tile-all。" >&2
exit 1
EOF

chmod +x "$target"

echo "快捷缩写已安装: $abbr -> terminal-tile-all"
if [[ ":$PATH:" != *":$bin_dir:"* ]]; then
  echo "注意：$bin_dir 不在 PATH 中。请先把它加入 shell PATH。"
fi
echo "现在可直接执行：$abbr"
